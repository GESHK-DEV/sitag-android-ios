{
  "expo": {
    "name": "pilot",
    "slug": "pilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "pilot",

    "fonts": [
      {
        "asset": "./assets/fonts/charlie-display.ttf"
      },
      {
        "asset": "./assets/fonts/charlie-display-3.ttf"
      },
      {
        "asset": "./assets/fonts/charlie-display-bold.ttf"
      },
      {
        "asset": "./assets/fonts/charlie-display-semibold.ttf"
      }
    ],
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-font"]
  }
}
